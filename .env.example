# === REQUIRED ===
JWT_SECRET=replace_with_a_long_random_secret

# === INITIAL SUPER ADMIN ===
# Used once on first boot to seed the super_admin account. Leave unset after
# first boot to skip seeding. In production both values are required — the
# server will refuse to auto-seed a default credential.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# === CORS ===
# Comma-separated origins allowed to call /api. Leave unset to use the default
# localhost list (dev). In production, nginx serves UI + API same-origin so
# CORS is not hit; set only if another host needs direct API access.
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# === DEPLOYMENT (for docker-compose.deploy.yml) ===
GITHUB_OWNER=sayedsafi2000
IMAGE_TAG=latest
# For client branches: IMAGE_TAG=client-abc-gym

# === GYM BRANDING (shown on receipts + UI) ===
GYM_NAME=GymPro Fitness
GYM_ADDRESS=Dhaka, Bangladesh
GYM_PHONE=+880 1XXXXXXXXX

# === FINGERPRINT DEVICE (optional) ===
ZKTECO_DEVICE_IP=
ZKTECO_DEVICE_PORT=4370
ATTENDANCE_POLL_INTERVAL_MS=60000

# === BACKUP (optional) ===
BACKUP_CRON=0 2 * * *
BACKUP_MAX_COUNT=7

# Google Drive backup (leave empty for local-only backups)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_TOKEN=
GDRIVE_FOLDER_ID=
