JWT_SECRET=replace_with_a_long_random_secret
GITHUB_OWNER=your_github_username_lowercase
IMAGE_TAG=latest

# Gym branding (shown on receipts)
GYM_NAME=GymPro Fitness
GYM_ADDRESS=Dhaka, Bangladesh
GYM_PHONE=+880 1XXXXXXXXX

# Backup schedule (cron format, default: daily at 2am)
BACKUP_CRON=0 2 * * *
# Number of backups to keep (older ones are rotated out)
BACKUP_MAX_COUNT=7

# Google Drive backup (optional — leave empty for local-only backups)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_TOKEN=
GDRIVE_FOLDER_ID=
